{
  "name": "percival",
  "author": "MakeAwesomeHappen",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "@rebble/clay": "^1.0.8"
  },
  "pebble": {
    "displayName": "Percival",
    "uuid": "e18ac84c-91e9-4b27-bf5b-ff5b85e6e85a",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "capabilities": ["configurable"],
    "messageKeys": {
      "TEMPERATURE": 0,
      "TEMP_HIGH": 1,
      "TEMP_LOW": 2,
      "CITY": 3,
      "PrimaryColor": 4,
      "SUNSET": 5,
      "MiniCompLeft": 6,
      "MiniCompMiddle": 7,
      "MiniCompRight": 8,
      "SUNRISE": 9,
      "BottomCompLeft": 10,
      "BottomCompPrimary": 11,
      "BottomCompRight": 12
    },
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "PEBBLE_LOGO",
          "file": "images/pebble_logo.png"
        },
        {
          "type": "png",
          "name": "SNEAKER_ICON",
          "file": "images/sneaker.png"
        },
        {
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_14",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[ -~]",
          "compatibility": "2.7"
        },
        {
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_18",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[0-9:\\-.k]",
          "compatibility": "2.7"
        },
{
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_28",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[ -~°]",
          "compatibility": "2.7"
        },
        {
          "type": "font",
          "name": "FONT_INTER_SEMIBOLD_68",
          "file": "fonts/Inter-SemiBold.ttf",
          "characterRegex": "[0-9: ]",
          "compatibility": "2.7"
        }
      ]
    }
  }
}
